#: data/org.ayatana.indicator.power.gschema.xml:1
msgid "Show time in Menu Bar"
msgstr "ສະແດງເວລາໃນແຖບເມນູ"

#: data/org.ayatana.indicator.power.gschema.xml:2
msgid "Whether or not to show the time in the menu bar."
msgstr "ຈະໃຫ້ສະແດງເວລາໃນແຖບເມນູ ຫຼືບໍ່."

#: data/org.ayatana.indicator.power.gschema.xml:3
msgid "Show percentage in Menu Bar"
msgstr "ສະແດງເປີເຊັນໃນແຖບເມນູ"

#: data/org.ayatana.indicator.power.gschema.xml:4
msgid "Whether or not to show the percentage in the menu bar."
msgstr "ຈະໃຫ້ສະແດງເປີເຊັນໃນແຖບເມນູ ຫຼືບໍ່."

#: data/org.ayatana.indicator.power.gschema.xml:5
msgid "When to show the battery status in the menu bar?"
msgstr "ຈະໃຫ້ສະແດງສະຖານະແບັດເຕີຣີໃນແຖບເມນູເມື່ອໃດ?"

#: data/org.ayatana.indicator.power.gschema.xml:6
msgid ""
"Options for when to show battery status. Valid options are \"present\", "
"\"charge\", and \"never\"."
msgstr ""
"ໂຕເລືອກສຳລັບເວລາທີ່ຈະສະແດງສະຖານະແບັດເຕີຣີ. ໂຕເລືອກທີ່ໃຊ້ໄດ້ແມ່ນ \"ເມື່ອມີແບັດເຕີຣີ\", "
"\"ເມື່ອກຳລັງສາກ\", ແລະ \"ບໍ່ສະແດງເລີຍ\"."

#. TRANSLATORS: system power cord
#: src/device.c:675
msgid "AC Adapter"
msgstr "ອະແດັບເຕີໄຟ AC"

#. TRANSLATORS: laptop primary battery
#: src/device.c:679 src/service.c:439
msgid "Battery"
msgstr "ແບັດເຕີຣີ"

#. TRANSLATORS: battery-backed AC power source
#: src/device.c:683
msgid "UPS"
msgstr "ເຄື່ອງສຳຮອງໄຟ"

#. TRANSLATORS: a monitor is a device to measure voltage and current
#: src/device.c:687
msgid "Monitor"
msgstr "ຈໍສະແດງຜົນ"

#. TRANSLATORS: wireless mice with internal batteries
#: src/device.c:691
msgid "Mouse"
msgstr "ເມົ້າສ໌"

#. TRANSLATORS: wireless keyboard with internal battery
#: src/device.c:695
msgid "Keyboard"
msgstr "ແປ້ນພິມ"

#. TRANSLATORS: portable device
#: src/device.c:699
msgid "PDA"
msgstr "ພີດີເອ"

#. TRANSLATORS: cell phone (mobile...)
#: src/device.c:703
msgid "Cell phone"
msgstr "ໂທລະສັບມືຖື"

#. TRANSLATORS: media player, mp3 etc
#: src/device.c:707
msgid "Media player"
msgstr "ເຄື່ອງຫຼິ້ນມີເດຍ"

#. TRANSLATORS: tablet device
#: src/device.c:711
msgid "Tablet"
msgstr "ແທັບເລັດ"

#. TRANSLATORS: tablet device
#: src/device.c:715
msgid "Computer"
msgstr "ຄອມພິວເຕີ"

#. TRANSLATORS: game controller/joystick with internal batteries
#: src/device.c:719
msgid "Gaming input"
msgstr "ອຸປະກອນຫຼິ້ນເກມ"

#. TRANSLATORS: graphic tablet pen with internal battery
#: src/device.c:723
msgid "Pen"
msgstr "ປາກກາ"

#: src/device.c:726
msgid "Touchpad"
msgstr "ທັດຊ໌ແພັດ"

#: src/device.c:729
msgid "Modem"
msgstr "ໂມເດັມ"

#: src/device.c:732
msgid "Network device"
msgstr "ອຸປະກອນເຄືອຂ່າຍ"

#: src/device.c:735
msgid "Headset"
msgstr "ຊຸດຫູຟັງ"

#. TRANSLATORS: loudspeakers with internal batteries
#: src/device.c:739
msgid "Speakers"
msgstr "ລຳໂພງ"

#: src/device.c:742
msgid "Headphones"
msgstr "ຫູຟັງ"

#: src/device.c:745
msgid "Video device"
msgstr "ອຸປະກອນວິດີໂອ"

#: src/device.c:748
msgid "Audio device"
msgstr "ອຸປະກອນສຽງ"

#. TRANSLATORS: remote control device with internal battery
#: src/device.c:752
msgid "Remote control"
msgstr "ຣີໂໝດຄວບຄຸມ"

#: src/device.c:755
msgid "Printer"
msgstr "ເຄື່ອງພິມ"

#: src/device.c:758
msgid "Scanner"
msgstr "ເຄື່ອງສະແກນ"

#: src/device.c:761
msgid "Camera"
msgstr "ກ້ອງ"

#: src/device.c:764
msgid "Wearable"
msgstr "ອຸປະກອນສວມໃສ່"

#: src/device.c:767
msgid "Toy"
msgstr "ເຄື່ອງຫຼິ້ນ"

#: src/device.c:770
msgid "Bluetooth device"
msgstr "ອຸປະກອນບລູທູທ"

#. TRANSLATORS: unknown device
#: src/device.c:774
msgid "Unknown"
msgstr "ບໍ່ຮູ້ຈັກ"

#: src/device.c:814
#, c-format
msgid "estimating…"
msgstr "ກຳລັງປະເມີນ…"

#: src/device.c:818
#, c-format
msgid "unknown"
msgstr "ບໍ່ຮູ້"

#. TRANSLATORS: H:MM (hours, minutes) to charge the battery. Example: "1:30 to charge"
#: src/device.c:847
#, c-format
msgid "%0d:%02d to charge"
msgstr "ສາກເຕັມໃນ %0d:%02d"

#. TRANSLATORS: H:MM (hours, minutes) to discharge the battery. Example: "1:30 left"
#: src/device.c:852
#, c-format
msgid "%0d:%02d left"
msgstr "ເຫຼືອ %0d:%02d"

#. TRANSLATORS: "X (hour,hours) Y (minute,minutes) to charge" the battery.
#. Example: "1 hour 10 minutes to charge"
#: src/device.c:887
#, c-format
msgid "%d %s %d %s to charge"
msgstr "ໃຊ້ເວລາສາກ %d %s %d %s"

#: src/device.c:888 src/device.c:906
msgid "hour"
msgid_plural "hours"
msgstr[0] "ຊົ່ວໂມງ"

#: src/device.c:889 src/device.c:896 src/device.c:907
#: src/device.c:914
msgid "minute"
msgid_plural "minutes"
msgstr[0] "ນາທີ"

#. TRANSLATORS: "Y (minute,minutes) to charge" the battery.
#. Example: "59 minutes to charge"
#: src/device.c:895
#, c-format
msgid "%d %s to charge"
msgstr "ໃຊ້ເວລາສາກ %d %s"

#. TRANSLATORS: "X (hour,hours) Y (minute,minutes) left" until the battery's empty.
#. Example: "1 hour 10 minutes left"
#: src/device.c:905
#, c-format
msgid "%d %s %d %s left"
msgstr "ເຫຼືອ %d %s %d %s"

#. TRANSLATORS: "Y (minute,minutes) left" until the battery's empty.
#. Example: "59 minutes left"
#: src/device.c:913
#, c-format
msgid "%d %s left"
msgstr "ເຫຼືອ %d %s"

#. TRANSLATORS: example: "battery (charged)"
#: src/device.c:979
#, c-format
msgid "%s (charged)"
msgstr "%s (ສາກເຕັມແລ້ວ)"

#. TRANSLATORS: example: "battery (time remaining)"
#: src/device.c:996
#, c-format
msgid "%s (%s)"
msgstr "%s (%s)"

#. TRANSLATORS: after the icon, a time-remaining string + battery %. Example: "0:59 33%"
#: src/device.c:1071
#, c-format
msgid "%s %.0lf%%"
msgstr "%s %.0lf%%"

#. TRANSLATORS: after the icon, a time-remaining string + battery %. Example: "(0:59, 33%)"
#: src/device.c:1075
#, c-format
msgid "(%s, %.0lf%%)"
msgstr "(%s, %.0lf%%)"

#. TRANSLATORS: after the icon, a time-remaining string Example: "0:59"
#: src/device.c:1084
#, c-format
msgid "%s"
msgstr "%s"

#. TRANSLATORS: after the icon, a time-remaining string Example: "(0:59)"
#: src/device.c:1088
#, c-format
msgid "(%s)"
msgstr "(%s)"

#. TRANSLATORS: after the icon, a battery %. Example: "(33%)"
#: src/device.c:1097
#, c-format
msgid "%.0lf%%"
msgstr "%.0lf%%"

#. TRANSLATORS: after the icon, a battery %. Example: "(33%)"
#: src/device.c:1101
#, c-format
msgid "(%.0lf%%)"
msgstr "(%.0lf%%)"

#: src/notifier.c:314
msgid "Battery Low"
msgstr "ແບັດເຕີຣີເຫຼືອໜ້ອຍ"

#: src/notifier.c:315
msgid "Battery Critical"
msgstr "ແບັດເຕີຣີໃກ້ຈະໝົດ"

#: src/notifier.c:317
#, c-format
msgid "%.0f%% charge remaining"
msgstr "ເຫຼືອພະລັງງານ %.0f%%"

#: src/notifier.c:347
msgid "OK"
msgstr "ຕົກລົງ"

#: src/notifier.c:348
msgid "Battery settings"
msgstr "ຕັ້ງຄ່າແບັດເຕີຣີ"

#: src/service.c:441
msgid "Battery status and power management"
msgstr "ສະຖານະແບັດເຕີຣີ ແລະ ການຈັດການພະລັງງານ"

#: src/service.c:532
msgid "Charge level"
msgstr "ລະດັບການສາກ"

#: src/service.c:633
msgid "Power Settings…"
msgstr "ຕັ້ງຄ່າພະລັງງານ…"

#: src/service.c:659
msgid "Adjust brightness automatically"
msgstr "ປັບຄວາມສະຫວ່າງອັດຕະໂນມັດ"

#: src/service.c:667
msgid "Flashlight"
msgstr "ໄຟສາຍ"

#: src/service.c:673
msgid "Warning: Heavy use can damage the LED!"
msgstr "ຄຳເຕືອນ: ການໃຊ້ງານໜັກອາດເຮັດໃຫ້ຫຼອດ LED ເສຍຫາຍໄດ້!"

#: src/service.c:679
msgid "Battery settings…"
msgstr "ຕັ້ງຄ່າແບັດເຕີຣີ…"

#: src/service.c:831 src/utils.c:68
msgid "Warning"
msgstr "ຄຳເຕືອນ"

#: src/service.c:832
msgid ""
"The Ayatana Power Indicator does not support evoking the\n"
"power statistics application of your desktop environment, yet.\n"
"\n"
"Please report this to the developers at:\n"
"https://github.com/ArcticaProject/ayatana-indicator-power/issues"
msgstr ""
"ຕົວຊີ້ບອກພະລັງງານ Ayatana ຍັງບໍ່ຮອງຮັບການເອີ້ນໃຊ້\n"
"ແອັບພລິເຄຊັນສະຖິຕິພະລັງງານຂອງສະພາບແວດລ້ອມເດັສທັອບຂອງທ່ານ.\n"
"\n"
"ກະລຸນາລາຍງານບັນຫານີ້ໃຫ້ກັບນັກພັດທະນາໄດ້ທີ່:\n"
"https://github.com/ArcticaProject/ayatana-indicator-power/issues"

#: src/utils.c:69
msgid ""
"The Ayatana Power Indicator does not support evoking the\n"
"power settings dialog of your desktop environment, yet.\n"
"\n"
"Please report this to the developers at:\n"
"https://github.com/ArcticaProject/ayatana-indicator-power/issues"
msgstr ""
"ຕົວຊີ້ບອກພະລັງງານ Ayatana ຍັງບໍ່ຮອງຮັບການເອີ້ນໃຊ້\n"
"ກ່ອງໂຕ້ຕອບການຕັ້ງຄ່າພະລັງງານຂອງສະພາບແວດລ້ອມເດັສທັອບຂອງທ່ານ.\n"
"\n"
"ກະລຸນາລາຍງານບັນຫານີ້ໃຫ້ກັບນັກພັດທະນາໄດ້ທີ່:\n"
"https://github.com/ArcticaProject/ayatana-indicator-power/issues"
